
<section id="chefs" class="chefs section-bg">
    <div class="container" data-aos="fade-up">

        <div class="section-header">
            <h2>@StaffBlock.Title</h2>
            <p>@StaffBlock.SubTitle</p>
        </div>

        <div class="row gy-4">

        @if (StaffBlock is null && StaffBlock?.StaffPeople is null)
        {
            <p><em>Loading...</em></p>
        }
        else
        {
           @foreach (var stf in StaffBlock.StaffPeople)
            {
                    <div class="col-lg-4 col-md-6 d-flex align-items-stretch" data-aos="fade-up" data-aos-delay="100">
                    <div class="chef-member">
                        <div class="member-img">
                            <img src="@stf.FullImageUrl" class="img-fluid" alt="">
                            <div class="social">
                                <a href=""><i class="bi bi-twitter"></i></a>
                                <a href=""><i class="bi bi-facebook"></i></a>
                                <a href=""><i class="bi bi-instagram"></i></a>
                                <a href=""><i class="bi bi-linkedin"></i></a>
                            </div>
                        </div>
                        <div class="member-info">
                            <h4>@stf.FullName</h4>
                            <span>@stf.Title</span>
                            <p>@stf.Descr</p>
                        </div>
                    </div>
                </div><!-- End Chefs Member -->
            }
        }

        </div>

    </div>
</section><!-- End Chefs Section -->


@code {

    [Parameter]
    public StaffBlock? StaffBlock { get; set; }

}