
<div class="container py-5 mb-5">
    <div class="row mb-4 align-items-center flex-lg-row-reverse">
        <div class="col-md-6 col-xl-7 mb-4 mb-lg-0 " style="">
            <!-- requires glightbox, please flag the option in the picostrap customizer panel-->

            <div class="lc-block position-relative">
                <img class="img-fluid rounded shadow" src="@HeroItem.FullImageUrl">
                <a class="position-absolute top-50 start-50 translate-middle glightbox d-flex justify-content-center align-items-center" href="https://www.youtube.com/watch?v=BKgpLOUYZJ4">
                 @*    <svg xmlns="http://www.w3.org/2000/svg" width="5em" height="5em" fill="currentColor" class="text-white" viewBox="0 0 16 16" lc-helper="svg-icon">
                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM6.79 5.093A.5.5 0 0 0 6 5.5v5a.5.5 0 0 0 .79.407l3.5-2.5a.5.5 0 0 0 0-.814l-3.5-2.5z"></path>
                    </svg> *@
                </a>
            </div>
        </div><!-- /col -->
        <div class="col-md-6 col-xl-5">
            <div class="lc-block mb-3">
                <div editable="rich">
                    <h1 class="fw-bolder display-2">@HeroItem.Title</h1>
                </div>
            </div><!-- /lc-block -->
            <!-- /lc-block -->
       
            <div class="lc-block mb-4">
                <div editable="rich">
                    <p class="lead">@ConvertedMarkdown</p>                

                </div>
            </div>
            <div class="lc-block">
                <a class="btn btn-lg btn-primary" href="@HeroItem.ActionUrl" role="button">@HeroItem.ActionTitle</a>
            </div><!-- /lc-block -->
        </div><!-- /col -->
    </div>
</div>

@code {
 
    private MarkupString ConvertedMarkdown;

    [Parameter]
    public HeroItemVm? HeroItem { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (HeroItem != null)
        {
            ConvertedMarkdown = (MarkupString)HeroItem.SubTitle;
        }

        await base.OnInitializedAsync();
    }
}