
<div class="b-example-divider"></div>

<div class="px-4 pt-5 my-5 text-center border-bottom">
    <h1 class="display-4 fw-bold">@HeroItem.Title</h1>
    <div class="col-lg-6 mx-auto">
        <p class="lead mb-4">@HeroItem.SubTitle</p>
        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mb-5">
            <button type="button" class="btn btn-primary btn-lg px-4 me-sm-3">@HeroItem.ActionTitle</button>
           @* <button type="button" class="btn btn-outline-secondary btn-lg px-4">Secondary</button>*@
        </div>
    </div>
    <div class="overflow-hidden" style="max-height: 130vh;">
        <div class="container px-5">
            <img src="@HeroItem.FullImageUrl" class="img-fluid border rounded-3 shadow-lg mb-4" alt="Example image" width="700" height="500" loading="lazy">
        </div>
    </div>
</div>

@code {

    [Parameter]
    public HeroItemVm? HeroItem { get; set; } 
}