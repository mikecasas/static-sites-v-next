@if (AboutUsItem is not null)
{
    <div class="container-xxl py-5">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-7">
                    <div class="row">
                        <div class="col-11">
                            <img class="img-fluid" src="@AboutUsItem.FullMainImageUrl">
                        </div>
                    </div>
                </div>

                <div class="col-lg-5 wow fadeIn" data-wow-delay="0.5s">
                    <p class="fw-medium text-uppercase text-primary-mike mb-2">About Us</p>
                    <h1 class="display-5 mb-4">@AboutUsItem.Title</h1>
                    <p class="mb-4">
                        @AboutUsItem.SubTitle
                    </p>

                    @if(@AboutUsItem.ItemList !=null){

                        <div class="d-flex align-items-center mb-4 border rounded-3">
                            <div class="flex-shrink-0 bg-primary p-4">
                                <h1 class="display-2 text-white">25</h1>
                                <h5 class="text-white">Years of</h5>
                                <h5 class="text-white">Experience</h5>
                            </div>
                            <div class="ms-4">

                                @foreach (var i in AboutUsItem.ItemList)
                                {
                                    @*<p><i class="fa fa-check text-primary me-2"></i>@i</p>*@
                                    <p class="mb-0"><i class="fa fa-check text-primary me-2"></i>@i</p>
                                }

                            </div>
                        </div>
                    }                   

                    <div class="row align-items-md-stretch">
                        <div class="col-md-12 mb-5">
                         @*   <div class="h-100 p-5 text-white bg-dark rounded-3">*@
                            <div class="h-100 p-5 text-white bg-primary rounded-3">
                                <h2>@AboutUsItem.Item1Title</h2>
                                <p>@AboutUsItem.Item1Description</p>
                               @* <button class="btn btn-outline-light" type="button">Example button</button>*@
                            </div>
                        </div>

                        @if (string.IsNullOrEmpty(@AboutUsItem.Item2Title))
                        {

                        }
                        else
                        {
                            <div class="col-md-12">
                                <div class="h-100 p-5 bg-light border rounded-3">
                                    <h2>@AboutUsItem.Item2Title</h2>
                                    <p>@AboutUsItem.Item2Description</p>
                                    @* <button class="btn btn-outline-secondary" type="button">Example button</button>*@
                                </div>
                            </div>
                        }

                        
                    </div>                   
                </div>
            </div>
        </div>
    </div>
}


