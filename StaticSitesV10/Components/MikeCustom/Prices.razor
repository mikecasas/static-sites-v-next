@if (PriceItem is not null){

    <div class="container py-3">
        <header>
            <div class="d-flex flex-column flex-md-row align-items-center pb-3 mb-4 border-bottom">
            </div>

            <div class="pricing-header p-3 pb-md-4 mx-auto text-center">
                <h1 class="display-6 fw-normal">@PriceItem.Title</h1>
                <p class="fs-5 text-muted">@PriceItem.Descr</p>
            </div>
        </header>

        <main>
            @*<div class="row row-cols-md-6 mb-3 text-center">*@
            <div class="row mb-3 text-center">

                <div class="col-12">
                    <div class="card mb-4 rounded-3 shadow-sm border-primary">
                        <div class="card-header py-3 text-white bg-primary border-primary">
                            <h4 class="my-0 fw-normal">@PriceItem.PriceTitle</h4>
                        </div>
                        <div class="card-body text-center">
                            <h1 class="card-title pricing-card-title">@PriceItem.ActualPrice<small class="text-muted fw-light"></small></h1>
                            <ul class="list-unstyled mt-3 mb-4">
                                @* <li>One Time Fee</li>*@
                                @* <li></li>
                            <li>Email support</li>*@

                                @if (PriceItem.FeatureCallouts.Any())
                                {
                                    foreach (var i in PriceItem.FeatureCallouts)
                                    {
                                        <li>@i</li>
                                    }
                                }
                            </ul>

                            <div>
                                <span class="fs-5 fw-bold">Additional questions or to get started?</span><br />
                                <span class="fs-5 fw-bold"><a href="@EmailLink" style="color:black">Email Us</a></span><br />
                                <span class="fs-5 fw-bold">@Email</span>

                            </div>


                            @*  <button type="button" class="w-100 btn btn-lg btn-primary">Additional questions or to get started? <br />
                            <span class="fs-5 fw-bold"><a href="@EmailLink" style="color:white">Email Us</a></span><br />
                            <span class="fs-5 fw-bold">@Email</span>

                        </button>   *@                                            

                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div class="b-example-divider"></div>

}


@code {

    private string EmailLink = string.Empty;

    [Parameter]
    public string? Email { get; set; }
  
    [Parameter]
    public PriceItem? PriceItem { get; set; }

    protected override void OnInitialized()
    {
        EmailLink = "mailto:" + Email;       
    }
}